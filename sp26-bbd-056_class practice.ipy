    "### Question 1\n",
    "### Class Person:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "021b7ae1-20fa-429c-8801-4843b304e5aa",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Person: Ali, Age: 22, City: Lahore\n"
     ]
    }
   ],
   "source": [
    "class Person:\n",
    "    def __init__(self, name, age, city):\n",
    "        self.name = name\n",
    "        self.age  = age\n",
    "        self.city = city\n",
    "\n",
    "    def __repr__(self):\n",
    "        return f\"Person: {self.name}, Age: {self.age}, City: {self.city}\"\n",
    "\n",
    "\n",
    "p = Person(\"Ali\", 22, \"Lahore\")\n",
    "print(p)"
   ]
  },
