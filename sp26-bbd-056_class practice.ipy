   "source": [
    "### Question 3\n",
    "### circle-area and circumference"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "d709cfa7-07e4-4ec0-a57a-4d89e45fb57d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Radius       : 5\n",
      "Area         : 78.5398\n",
      "Circumference: 31.4159\n"
     ]
    }
   ],
   "source": [
    "\n",
    "import math\n",
    "\n",
    "class Circle:\n",
    "    def __init__(self, radius):\n",
    "        self.radius = radius\n",
    "\n",
    "    def area(self):\n",
    "        return round(math.pi * self.radius**2, 4)\n",
    "\n",
    "    def circumference(self):\n",
    "        return round(2 * math.pi * self.radius, 4)\n",
    "\n",
    "c = Circle(5)\n",
    "print(\"Radius       :\", c.radius)\n",
    "print(\"Area         :\", c.area())\n",
    "print(\"Circumference:\", c.circumference())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2ce2e0cf-c4c6-4b92-b4b8-7879c44c4ee1",
   "metadata": {},
   "source": [
    "### Question 4\n",
    "### Rectangle_area and perimeter"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "084264bd-7e86-47b0-984a-c6430323cd83",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Length   : 4\n",
      "Width    : 6\n",
      "Area     : 24\n",
      "Perimeter: 20\n"
     ]
    }
   ],
   "source": [
    "class Rectangle:\n",
    "    def __init__(self, length, width):\n",
    "        self.length = length\n",
    "        self.width  = width\n",
    "\n",
    "    def area(self):\n",
    "        return self.length * self.width\n",
    "\n",
    "    def perimeter(self):\n",
    "        return 2 * (self.length + self.width)\n",
    "\n",
    "    def display(self):\n",
    "        print(f\"Length   : {self.length}\")\n",
    "        print(f\"Width    : {self.width}\")\n",
    "        print(f\"Area     : {self.area()}\")\n",
    "        print(f\"Perimeter: {self.perimeter()}\")\n",
    "\n",
    "\n",
    "r = Rectangle(4, 6)\n",
    "r.display()"
   ]
  },
  {
   "cell_type": "markdown",
