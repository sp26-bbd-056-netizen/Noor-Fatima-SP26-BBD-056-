    "        self.year  = year\n",
    "\n",
    "    def display(self):\n",
    "        print(f\"Make  : {self.make}\")\n",
    "        print(f\"Model : {self.model}\")\n",
    "        print(f\"Year  : {self.year}\")\n",
    "\n",
    "c = Car(\"Toyota\", \"Corolla\", 2022)\n",
    "c.display()"
   ]
